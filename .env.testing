# ===========================================================================
# ZCloud Security Platform — Testing Environment
# ===========================================================================
# Used for automated tests (CI/CD pipelines and local test runs).
# Secrets should be injected by the CI system via environment variables or
# a secrets manager — do NOT hardcode real credentials here.
# ===========================================================================

NODE_ENV=testing

# Application
APP_NAME="ZCloud Security Platform"
APP_VERSION=1.0.0
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=warn

# Database — use a dedicated test database to avoid polluting dev/prod data
DATABASE_URL=postgresql://zcloud_test:changeme@localhost:5432/zcloud_test

# Security — use a fixed test secret so test runs are deterministic;
# this must NEVER be used outside of the test environment
JWT_SECRET=test-only-jwt-secret-not-for-production
JWT_EXPIRES_IN=1h

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3001

# Rate limiting — relaxed for automated test throughput
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# Cache
CACHE_TTL_SECONDS=10
# REDIS_URL=redis://localhost:6379

# Database pool
DB_POOL_MIN=1
DB_POOL_MAX=3
