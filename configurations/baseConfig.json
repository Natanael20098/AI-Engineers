{
  "app": {
    "name": "ZCloud Security Platform",
    "version": "1.0.0",
    "port": 3000,
    "logLevel": "info"
  },
  "server": {
    "host": "0.0.0.0",
    "requestTimeoutMs": 30000,
    "maxRequestBodySizeKb": 1024
  },
  "security": {
    "bcryptSaltRounds": 12,
    "jwtExpiresIn": "1h",
    "corsAllowedOrigins": []
  },
  "database": {
    "poolMin": 2,
    "poolMax": 10,
    "acquireTimeoutMs": 30000,
    "idleTimeoutMs": 10000
  },
  "rateLimit": {
    "windowMs": 60000,
    "maxRequests": 100
  },
  "cache": {
    "ttlSeconds": 300
  }
}
